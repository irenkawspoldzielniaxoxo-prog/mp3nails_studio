<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>MP3 Nails Studio</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500;600&family=Pinyon+Script&family=League+Spartan:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

  :root {
    --gold: #c9a84c;
    --gold-light: #e8d5a3;
    --gold-dark: #8a6f32;
    --black: #0a0a0a;
    --dark: #111111;
    --dark2: #1a1a1a;
    --white: #f5f0eb;
    --gray: #888;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Montserrat', sans-serif;
    background: var(--black);
    color: var(--white);
    overflow-x: hidden;
  }

  #particles {
    position: fixed; inset: 0;
    pointer-events: none; z-index: 0;
    overflow: hidden;
  }
  .particle {
    position: absolute;
    width: 2px; height: 2px;
    background: var(--gold);
    border-radius: 50%;
    animation: floatUp linear infinite;
    opacity: 0;
  }
  @keyframes floatUp {
    0%   { transform: translateY(100vh) scale(0); opacity: 0; }
    10%  { opacity: 0.6; }
    90%  { opacity: 0.3; }
    100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
  }

  nav {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 60px;
    background: linear-gradient(to bottom, rgba(0,0,0,0.9) 0%, transparent 100%);
    transition: background 0.4s;
  }
  nav.scrolled { background: rgba(10,10,10,0.97); border-bottom: 1px solid rgba(201,168,76,0.2); }

  .logo {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 4px;
    color: var(--gold);
    text-transform: uppercase;
  }
  .logo span { font-style: italic; color: var(--white); font-weight: 300; }

  .hero-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 1s 0.5s forwards;
  }
  .hero-logo-mp3 {
    font-family: 'Copperplate Gothic', 'Copperplate', 'Papyrus', serif;
    font-size: clamp(3.5rem, 8vw, 7rem);
    font-weight: 400;
    color: var(--gold);
    letter-spacing: 10px;
    text-transform: uppercase;
    line-height: 1;
  }
  .hero-logo-nails {
    font-family: 'League Spartan', sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.6rem);
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.55em;
    text-transform: uppercase;
    line-height: 1.3;
  }
  .hero-logo-studio {
    font-family: 'Pinyon Script', cursive;
    font-size: clamp(3.2rem, 6.5vw, 6rem);
    font-weight: 400;
    background: linear-gradient(135deg, #c9a84c 0%, #f0d980 40%, #e8d5a3 60%, #a8742a 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 3px;
    margin-top: -4px;
  }

  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    font-size: 0.7rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--white);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.3s, color 0.3s;
    position: relative;
  }
  .nav-links a::after {
    content: '';
    position: absolute; bottom: -4px; left: 0; right: 0;
    height: 1px; background: var(--gold);
    transform: scaleX(0); transition: transform 0.3s;
  }
  .nav-links a:hover { opacity: 1; color: var(--gold); }
  .nav-links a:hover::after { transform: scaleX(1); }

  .hero {
    position: relative;
    height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center top, rgba(201,168,76,0.12) 0%, transparent 70%),
                radial-gradient(ellipse at 80% 80%, rgba(201,168,76,0.06) 0%, transparent 50%),
                linear-gradient(135deg, #0a0a0a 0%, #111 50%, #0d0d0d 100%);
  }
  .hero-line {
    position: absolute;
    top: 0; left: 50%; transform: translateX(-50%);
    width: 1px; height: 120px;
    background: linear-gradient(to bottom, transparent, var(--gold));
    animation: lineDown 1.5s ease forwards;
  }
  @keyframes lineDown { from { height: 0; opacity: 0; } to { height: 120px; opacity: 1; } }

  .hero-tag {
    font-size: 0.65rem;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 1s 0.5s forwards;
  }
  .hero h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(4rem, 9vw, 8rem);
    font-weight: 300;
    line-height: 1;
    letter-spacing: 8px;
    text-transform: uppercase;
    opacity: 0;
    animation: fadeUp 1s 0.7s forwards;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--gold);
    display: block;
    font-weight: 300;
  }
  .hero-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--gold-light);
    margin-top: 20px;
    letter-spacing: 2px;
    opacity: 0;
    animation: fadeUp 1s 0.9s forwards;
  }
  .hero-divider {
    display: flex; align-items: center; gap: 16px;
    margin: 36px 0;
    opacity: 0;
    animation: fadeUp 1s 1.1s forwards;
  }
  .hero-divider span { width: 60px; height: 1px; background: var(--gold); }
  .hero-divider i { font-size: 0.7rem; letter-spacing: 4px; color: var(--gold); font-style: normal; }
  .btn-gold {
    display: inline-block;
    padding: 16px 48px;
    border: 1px solid var(--gold);
    color: var(--gold);
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    position: relative;
    overflow: hidden;
    transition: color 0.4s;
    opacity: 0;
    animation: fadeUp 1s 1.3s forwards;
  }
  .btn-gold::before {
    content: '';
    position: absolute; inset: 0;
    background: var(--gold);
    transform: translateX(-100%);
    transition: transform 0.4s ease;
    z-index: -1;
  }
  .btn-gold:hover { color: var(--black); }
  .btn-gold:hover::before { transform: translateX(0); }

  .scroll-hint {
    position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0;
    animation: fadeUp 1s 1.8s forwards;
  }
  .scroll-hint span { font-size: 0.55rem; letter-spacing: 4px; color: var(--gray); }
  .scroll-arrow {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  section { position: relative; z-index: 1; }

  .strip {
    background: var(--gold);
    padding: 20px 0;
    overflow: hidden;
  }
  .strip-inner {
    display: flex; gap: 60px;
    animation: marquee 20s linear infinite;
    white-space: nowrap;
  }
  .strip-item {
    font-size: 0.65rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--black);
    font-weight: 600;
    display: flex; align-items: center; gap: 20px;
  }
  .strip-item::after { content: '✦'; font-size: 0.5rem; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .about {
    padding: 140px 60px;
    display: flex;
    justify-content: center;
    max-width: 800px; margin: 0 auto;
  }
  .section-label {
    font-size: 0.6rem;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 4vw, 3.8rem);
    font-weight: 300;
    line-height: 1.15;
    margin-bottom: 28px;
  }
  .section-title em { font-style: italic; color: var(--gold); }
  .section-text {
    font-size: 0.8rem;
    line-height: 2;
    color: rgba(245,240,235,0.65);
    font-weight: 300;
  }

  .services-section {
    padding: 100px 60px;
    background: linear-gradient(135deg, var(--dark) 0%, var(--black) 100%);
    text-align: center;
  }
  .services-section .section-title { margin-bottom: 60px; }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    max-width: 1100px; margin: 0 auto;
  }
  .service-card {
    background: var(--dark2);
    padding: 60px 40px;
    position: relative;
    overflow: hidden;
    cursor: default;
    transition: background 0.4s;
  }
  .service-card::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(201,168,76,0.08), transparent);
    opacity: 0; transition: opacity 0.4s;
  }
  .service-card:hover { background: #1e1e1e; }
  .service-card:hover::before { opacity: 1; }
  .service-card::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, var(--gold), transparent);
    transform: scaleX(0); transition: transform 0.4s;
  }
  .service-card:hover::after { transform: scaleX(1); }
  .service-icon {
    font-size: 2.5rem;
    margin-bottom: 24px;
    display: block;
    color: var(--gold);
  }
  .material-symbols-outlined {
    font-size: 2.8rem !important;
    color: var(--gold);
  }
  .service-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 400;
    margin-bottom: 12px;
    color: var(--white);
  }
  .service-desc {
    font-size: 0.72rem;
    color: rgba(245,240,235,0.5);
    line-height: 1.9;
    font-weight: 300;
    margin-bottom: 24px;
  }
  .service-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    color: var(--gold);
    letter-spacing: 2px;
  }

  .gallery-section {
    padding: 120px 0;
    overflow: hidden;
  }
  .gallery-header {
    text-align: center;
    padding: 0 60px;
    margin-bottom: 70px;
  }
  .gallery-track {
    display: flex; gap: 20px;
    padding: 0 60px;
    overflow-x: auto;
    scrollbar-width: none;
    cursor: grab;
  }
  .gallery-track::-webkit-scrollbar { display: none; }
  .gallery-item {
    flex: 0 0 280px;
    height: 380px;
    border: 1px solid rgba(201,168,76,0.2);
    background: var(--dark2);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    position: relative;
    overflow: hidden;
    transition: transform 0.4s, border-color 0.4s;
  }
  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    cursor: zoom-in;
  }
  .gallery-item:hover { transform: scale(1.03); border-color: var(--gold); }

  /* LIGHTBOX */
  .lightbox {
    position: fixed; inset: 0;
    z-index: 999;
    background: rgba(0,0,0,0.93);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.35s ease;
  }
  .lightbox.active { opacity: 1; pointer-events: all; }
  .lightbox-inner {
    position: relative;
    max-width: 90vw; max-height: 90vh;
    display: flex; flex-direction: column; align-items: center; gap: 16px;
    transform: scale(0.92);
    transition: transform 0.35s ease;
  }
  .lightbox.active .lightbox-inner { transform: scale(1); }
  .lightbox-inner img {
    max-width: 90vw; max-height: 80vh;
    object-fit: contain;
    border: 1px solid rgba(201,168,76,0.3);
    box-shadow: 0 0 80px rgba(0,0,0,0.8);
  }
  .lightbox-caption {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: var(--gold-light);
    letter-spacing: 2px;
  }
  .lightbox-close {
    position: absolute; top: -44px; right: 0;
    background: none; border: none;
    color: var(--gold); font-size: 1.6rem;
    cursor: pointer; line-height: 1;
    opacity: 0.7; transition: opacity 0.2s;
  }
  .lightbox-close:hover { opacity: 1; }
  .lightbox-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    background: none; border: 1px solid rgba(201,168,76,0.3);
    color: var(--gold); font-size: 1.2rem;
    width: 48px; height: 48px;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background 0.2s, border-color 0.2s;
  }
  .lightbox-arrow:hover { background: rgba(201,168,76,0.15); border-color: var(--gold); }
  .lightbox-prev { left: -70px; }
  .lightbox-next { right: -70px; }
  .gallery-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
    display: flex; align-items: flex-end;
    padding: 24px;
    opacity: 0; transition: opacity 0.4s;
  }
  .gallery-item:hover .gallery-overlay { opacity: 1; }
  .gallery-overlay span {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1rem;
    color: var(--gold-light);
    font-style: italic;
    letter-spacing: 1px;
  }

  .stats {
    padding: 100px 60px;
    background: linear-gradient(135deg, var(--dark) 0%, #0d0d0d 100%);
    border-top: 1px solid rgba(201,168,76,0.15);
    border-bottom: 1px solid rgba(201,168,76,0.15);
  }
  .stats-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    max-width: 1100px; margin: 0 auto;
    text-align: center;
    gap: 40px;
  }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 4.5rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
  }
  .stat-label {
    font-size: 0.62rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(245,240,235,0.5);
  }

  .booking {
    padding: 140px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .booking-bg {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at center, rgba(201,168,76,0.08) 0%, transparent 70%);
  }
  .booking h2 {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 300;
    margin-bottom: 20px;
  }
  .booking h2 em { font-style: italic; color: var(--gold); }
  .booking p {
    font-size: 0.78rem;
    letter-spacing: 1px;
    color: rgba(245,240,235,0.5);
    margin-bottom: 50px;
    line-height: 2;
    font-weight: 300;
  }
  .booking-form {
    display: grid; grid-template-columns: 1fr 1fr 1fr auto;
    gap: 2px; max-width: 900px; margin: 0 auto;
  }
  .form-field {
    background: var(--dark2);
    border: 1px solid rgba(201,168,76,0.2);
    padding: 20px 28px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 2px;
    color: var(--white);
    outline: none;
    transition: border-color 0.3s;
    appearance: none;
  }
  .form-field::placeholder { color: rgba(245,240,235,0.3); }
  .form-field:focus { border-color: var(--gold); }
  option { background: #111; }
  .btn-book {
    background: var(--gold);
    border: none;
    padding: 20px 36px;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--black);
    cursor: pointer;
    font-weight: 600;
    transition: background 0.3s;
  }
  .btn-book:hover { background: var(--gold-light); }

  footer {
    padding: 80px 60px 40px;
    background: #060606;
    border-top: 1px solid rgba(201,168,76,0.15);
  }
  .footer-top {
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 60px; margin-bottom: 60px;
  }
  .footer-brand .logo { font-size: 1.3rem; margin-bottom: 20px; display: block; }
  .footer-brand p {
    font-size: 0.72rem;
    color: rgba(245,240,235,0.4);
    line-height: 2;
    font-weight: 300;
    max-width: 280px;
  }
  .footer-col h4 {
    font-size: 0.6rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 24px;
  }
  .footer-col a, .footer-col p {
    display: block;
    font-size: 0.72rem;
    color: rgba(245,240,235,0.4);
    text-decoration: none;
    margin-bottom: 12px;
    line-height: 1.8;
    transition: color 0.3s;
  }
  .footer-col a:hover { color: var(--gold); }
  .footer-bottom {
    border-top: 1px solid rgba(201,168,76,0.1);
    padding-top: 30px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .footer-bottom p { font-size: 0.62rem; color: rgba(245,240,235,0.25); letter-spacing: 1px; }
  .social-links { display: flex; gap: 20px; }
  .social-links a {
    width: 36px; height: 36px;
    border: 1px solid rgba(201,168,76,0.3);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem;
    text-decoration: none;
    color: var(--gold);
    transition: background 0.3s, border-color 0.3s;
  }
  .social-links a:hover { background: var(--gold); color: var(--black); }

  .gold-line {
    display: flex; align-items: center; gap: 20px;
    margin-bottom: 20px;
  }
  .gold-line::before, .gold-line::after {
    content: ''; flex: 1;
    height: 1px; background: rgba(201,168,76,0.4);
  }
  .gold-line span { font-size: 0.8rem; color: var(--gold); }

  @media(max-width:900px){
    nav{ padding: 20px 24px; }
    .nav-links{ display: none; }
    .about{ grid-template-columns: 1fr; padding: 80px 24px; gap: 60px; }
    .services-grid{ grid-template-columns: 1fr; }
    .stats-grid{ grid-template-columns: 1fr 1fr; }
    .booking-form{ grid-template-columns: 1fr; }
    .footer-top{ grid-template-columns: 1fr 1fr; }
    .services-section,.gallery-section,.booking,.stats{ padding-left:24px; padding-right:24px; }
  }
</style>
</head>
<body>

<div id="particles"></div>

<nav id="nav">
  <div class="logo" style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:600;letter-spacing:4px;color:var(--gold);text-transform:uppercase;">MP3 <span style="font-style:italic;color:var(--white);font-weight:300;">Nails Studio</span></div>
  <ul class="nav-links">
    <li><a href="#uslugi">Usługi</a></li>
    <li><a href="#galeria">Galeria</a></li>
    <li><a href="#o-nas">O nas</a></li>
    <li><a href="#rezerwacja">Rezerwacja</a></li>
    <li><a href="#kontakt">Kontakt</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-line"></div>
  <div class="hero-logo">
    <div class="hero-logo-mp3">MP3</div>
    <div class="hero-logo-nails">NAILS</div>
    <div class="hero-logo-studio">Studio</div>
  </div>
  <p class="hero-sub" style="opacity:0;animation:fadeUp 1s 0.9s forwards;">Gdzie sztuka spotyka się z doskonałością</p>
  <div class="hero-divider" style="opacity:0;animation:fadeUp 1s 1.1s forwards;">
    <span></span><i>✦ Prestiż ✦ Elegancja ✦ Precyzja ✦</i><span></span>
  </div>
  <a href="#rezerwacja" class="btn-gold">Zarezerwuj Wizytę</a>
  <div class="scroll-hint">
    <span>Scroll</span>
    <div class="scroll-arrow"></div>
  </div>
</section>

<div class="strip">
  <div class="strip-inner" id="strip">
    <span class="strip-item">Manicure Hybrydowy</span>
    <span class="strip-item">Żel & Akryl</span>
    <span class="strip-item">Nail Art</span>
    <span class="strip-item">French Elegance</span>
    <span class="strip-item">Pedicure Spa</span>
    <span class="strip-item">Przedłużanie Paznokci</span>
    <span class="strip-item">Zdobienia 3D</span>
    <span class="strip-item">Laminowanie</span>
    <span class="strip-item">Manicure Hybrydowy</span>
    <span class="strip-item">Żel & Akryl</span>
    <span class="strip-item">Nail Art</span>
    <span class="strip-item">French Elegance</span>
    <span class="strip-item">Pedicure Spa</span>
    <span class="strip-item">Przedłużanie Paznokci</span>
    <span class="strip-item">Zdobienia 3D</span>
    <span class="strip-item">Laminowanie</span>
  </div>
</div>

